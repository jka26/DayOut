# DayOut — Environment Variables Template
# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit real keys.

# OpenWeatherMap — free at https://openweathermap.org/api
OPENWEATHERMAP_KEY=your_openweathermap_key_here

# Foursquare Places API v3 — free at https://foursquare.com/developers/signup
FOURSQUARE_KEY=your_foursquare_key_here

# Google Places API — https://console.cloud.google.com
# Requires billing enabled (free tier: $200/month credit)
GOOGLE_PLACES_KEY=your_google_places_key_here
