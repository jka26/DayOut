# DayOut Backend — Apache configuration

# Handle CORS preflight (OPTIONS) requests globally
RewriteEngine On
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^(.*)$ $1 [R=204,L]

# Set CORS and content-type headers for all responses
Header always set Access-Control-Allow-Origin "*"
Header always set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
Header always set Access-Control-Allow-Headers "Content-Type, Authorization, Accept"
Header always set Content-Type "application/json; charset=utf-8"

# Disable directory listing
Options -Indexes

# Deny access to .env files
<FilesMatch "^\.env">
    Order allow,deny
    Deny from all
</FilesMatch>
